# 数据库配置（可选 - 默认使用 SQLite）
# 如果要使用 MySQL，请取消注释并填写以下配置
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=ideaDesign

# SQLite 配置（默认）
SQLITE_DB_PATH=data/ideaDesign.db

# Flask 配置
FLASK_ENV=development
FLASK_DEBUG=True

# 默认 API 配置（可选，用户可在前端覆盖）
DEFAULT_API_KEY=your_openai_api_key
DEFAULT_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o
